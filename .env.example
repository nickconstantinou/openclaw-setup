# OpenClaw — Environment Configuration
#
# HOW API KEYS WORK:
#
#   .env  ──→  environment.d/openclaw.conf  ──→  process.env
#                                                     │
#              [SECRETREF] keys are also stored ──────┘
#              as SecretRef objects in openclaw.json.
#              openclaw's secrets system resolves them
#              at gateway startup (fail-fast on missing).
#
#              [ENV-ONLY] keys are read directly from
#              process.env by openclaw or other tools.
#              No SecretRef object in openclaw.json.
#
# UPDATING A KEY:
#   1. Edit this file with the new value
#   2. Re-run the deploy script
#   3. environment.d is updated; gateway picks it up on restart
#
# This file must be kept intact — the deploy script sources it on
# every run. Keep permissions at: chmod 600 ~/.openclaw/.env

# ── DEPLOY ───────────────────────────────────────────────────────────────────
# SHA256 of openclaw-install.sh for integrity verification.
# Run: sha256sum openclaw-install.sh | awk '{print $1}'
OPENCLAW_INSTALLER_SHA256=REPLACE_ME

# ── CHANNELS (ENV-ONLY) ───────────────────────────────────────────────────────
# Read directly by openclaw gateway. Not stored in openclaw.json.
# Create bot via @BotFather. Get chat ID via @userinfobot.
TELEGRAM_BOT_TOKEN=123456789:ABCDefGhIJKlmNoPQRsTUVwxyZ
TELEGRAM_CHAT_ID=123456789

# ── SECRETREF KEYS ────────────────────────────────────────────────────────────
# Written to environment.d AND stored as SecretRef in openclaw.json under
# models.providers.*.apiKey and skills.entries.*.apiKey.
# openclaw resolves these at startup — gateway refuses to start if a key is
# missing/empty and the surface is active.

# Primary AI provider — required
# https://platform.minimaxi.com/
MINIMAX_API_KEY=mm-REPLACE_ME

# NVIDIA NIM — optional GPU models + image generation skill
# https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-REPLACE_ME_WHEN_READY

# Tavily — optional web search skill
# https://tavily.com/
TAVILY_API_KEY=tvly-REPLACE_ME_WHEN_READY

# Post Bridge — optional social media management skill
POST_BRIDGE_API_KEY=pb_REPLACE_ME_WHEN_READY

# ── ENV-ONLY KEYS ─────────────────────────────────────────────────────────────
# Written to environment.d. Read directly from process.env. NOT in openclaw.json.

# Google Gemini — required for media processing (image/audio/video)
# openclaw's built-in 'google' provider reads GEMINI_API_KEY natively from process.env.
# https://aistudio.google.com/
GEMINI_API_KEY=AIzaSy-REPLACE_ME

# Anthropic Claude — optional fallback model provider
# openclaw's built-in 'anthropic' provider reads ANTHROPIC_API_KEY natively from process.env.
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME_WHEN_READY

# GitHub — git operations and automation
# Classic PAT with 'repo' scope: https://github.com/settings/tokens
GITHUB_API_KEY=ghp_REPLACE_ME

# GOG — optional game asset extraction / transcription
GOG_ACCOUNT=your@email.com
GOG_KEYRING_PASSWORD=REPLACE_ME

# ── PATHS (ENV-ONLY) ──────────────────────────────────────────────────────────
# Absolute path to your Obsidian vault
OBSIDIAN_VAULT_PATH=/home/user/Documents/ObsidianVault
