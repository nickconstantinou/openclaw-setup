# OpenClaw — Environment Configuration
#
# HOW API KEYS WORK:
#
#   .env  ──→  environment.d/openclaw.conf  ──→  process.env
#                                                     │
#              [SECRETREF] keys are also stored ──────┘
#              as SecretRef objects in openclaw.json.
#              openclaw's secrets system resolves them
#              at gateway startup (fail-fast on missing).
#
#              [ENV-ONLY] keys are read directly from
#              process.env by openclaw or other tools.
#              No SecretRef object in openclaw.json.
#
# UPDATING A KEY:
#   1. Edit this file with the new value
#   2. Re-run the deploy script
#   3. environment.d is updated; gateway picks it up on restart
#
# This file must be kept intact — the deploy script sources it on
# every run. Keep permissions at: chmod 600 ~/.openclaw/.env

# ── DEPLOY ───────────────────────────────────────────────────────────────────
# SHA256 of openclaw-install.sh for integrity verification.
# Run: sha256sum openclaw-install.sh | awk '{print $1}'
OPENCLAW_INSTALLER_SHA256=REPLACE_ME

# ── CHANNELS (ENV-ONLY) ───────────────────────────────────────────────────────
# Read directly by openclaw gateway. Not stored in openclaw.json.
# Create bot via @BotFather. Get chat ID via @userinfobot.
TELEGRAM_BOT_TOKEN=123456789:ABCDefGhIJKlmNoPQRsTUVwxyZ
TELEGRAM_CHAT_ID=123456789
TELEGRAM_BOT_TOKEN_CODING=tg-REPLACE_ME_CODING
TELEGRAM_BOT_TOKEN_MARKETING=tg-REPLACE_ME_MARKETING
# WhatsApp (family agent) uses QR-based credential linking — no token required

# ── SECURITY: ACCESS CONTROL ──────────────────────────────────────────────────
# Telegram User IDs allowed to DM your bots (comma-separated for multiple users)
# Get your ID from @userinfobot (search for @userinfobot in Telegram)
#
# SMART DEFAULT: If left as REPLACE_ME, automatically uses TELEGRAM_CHAT_ID (set above)
#                This gives you instant access to your own bot without manual config.
#
# Examples:
#   Auto (uses TELEGRAM_CHAT_ID):  TELEGRAM_ALLOWED_USERS=REPLACE_ME
#   Single user:                   TELEGRAM_ALLOWED_USERS=123456789
#   Multiple users:                TELEGRAM_ALLOWED_USERS=123456789,987654321,555111222
#
# NOTE: Group messages are always DISABLED for security. This controls DM access only.
TELEGRAM_ALLOWED_USERS=REPLACE_ME

# Per-bot access control (optional) — if not set, inherits from TELEGRAM_ALLOWED_USERS
# Use these to restrict who can access specific bots:
#
# CODING bot has bash/exec access — restrict to trusted developers only!
# Example: TELEGRAM_ALLOWED_USERS_CODING=123456789 (only you)
TELEGRAM_ALLOWED_USERS_CODING=INHERIT

# MARKETING bot has content creation tools — restrict to marketing team
# Example: TELEGRAM_ALLOWED_USERS_MARKETING=987654321,555111222 (team members)
TELEGRAM_ALLOWED_USERS_MARKETING=INHERIT

# WhatsApp numbers allowed to DM (international format without +, comma-separated)
# Example: US number +1-415-555-2671 becomes 14155552671
#
# PAIRING MODE: Leave as REPLACE_ME to use pairing mode — users must authenticate
#               via QR code or pairing command before accessing the bot.
#
# Examples:
#   Pairing mode (requires approval): WHATSAPP_ALLOWED_USERS=REPLACE_ME
#   Single number:                    WHATSAPP_ALLOWED_USERS=14155552671
#   Multiple numbers:                 WHATSAPP_ALLOWED_USERS=14155552671,442071234567
#
# NOTE: Group messages are always DISABLED for security. This controls DM access only.
WHATSAPP_ALLOWED_USERS=REPLACE_ME

# ── SECRETREF KEYS ────────────────────────────────────────────────────────────
# Written to environment.d AND stored as SecretRef in openclaw.json under
# models.providers.*.apiKey and skills.entries.*.apiKey.
# openclaw resolves these at startup — gateway refuses to start if a key is
# missing/empty and the surface is active.

# Primary AI provider — required
# https://platform.minimaxi.com/
MINIMAX_API_KEY=mm-REPLACE_ME

# NVIDIA NIM — optional GPU models + image generation skill
# https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-REPLACE_ME_WHEN_READY

# Tavily — optional web search skill
# https://tavily.com/
TAVILY_API_KEY=tvly-REPLACE_ME_WHEN_READY

# Post Bridge — optional social media management skill
POST_BRIDGE_API_KEY=pb_REPLACE_ME_WHEN_READY

# ── ENV-ONLY KEYS ─────────────────────────────────────────────────────────────
# Written to environment.d. Read directly from process.env. NOT in openclaw.json.

# Google Gemini — required for media processing (image/audio/video)
# openclaw's built-in 'google' provider reads GEMINI_API_KEY natively from process.env.
# https://aistudio.google.com/
GEMINI_API_KEY=AIzaSy-REPLACE_ME

# Anthropic Claude — optional fallback model provider
# openclaw's built-in 'anthropic' provider reads ANTHROPIC_API_KEY natively from process.env.
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME_WHEN_READY

# GitHub — git operations and automation
# Classic PAT with 'repo' scope: https://github.com/settings/tokens
GITHUB_PAT=ghp_REPLACE_ME

# Google Workspace CLI (gws) — optional; used for Gmail, Calendar, Drive, Sheets, Docs
# Obtain OAuth 2.0 credentials: https://console.cloud.google.com/ → APIs & Services → Credentials
# After adding these, run: gws auth setup && gws auth login
GOOGLE_WORKSPACE_CLI_CLIENT_ID=REPLACE_ME
GOOGLE_WORKSPACE_CLI_CLIENT_SECRET=REPLACE_ME
# Use file-based encryption key instead of OS keyring (headless/sandbox-safe)
GOOGLE_WORKSPACE_CLI_KEYRING_BACKEND=file

# ── PATHS (ENV-ONLY) ──────────────────────────────────────────────────────────
# Absolute path to your Obsidian vault
OBSIDIAN_VAULT_PATH=/home/user/Documents/ObsidianVault

# Sandbox execution mode controls
# 'untrusted' (default) = run tools locally
# 'all' = run tools securely in a docker container
OPENCLAW_SANDBOX_MODE="untrusted"

# ── BROWSER AUTOMATION ────────────────────────────────────────────────────────
# LightPanda CDP browser — optional fast headless browser (10x faster than Chrome)
# Default values work out of the box; override only if port conflicts arise.
LIGHTPANDA_HOST=127.0.0.1
LIGHTPANDA_PORT=9222
